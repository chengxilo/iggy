common --enable_bzlmod

# CI configuration, mirroring foreign/cpp: bazel 9 defaults to lockfile_mode=update, which
# silently rewrites a stale MODULE.bazel.lock; error mode makes drift fail the build instead.
common:ci --color=no
common:ci --curses=no
common:ci --announce_rc
build:ci --lockfile_mode=error
